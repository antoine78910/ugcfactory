{
  "firewall": {
    "rules": [
      {
        "name": "Rate limit generation APIs (Kling, Veo, NanoBanana, Studio)",
        "conditionGroup": [
          {
            "conditions": [
              {
                "type": "path",
                "op": "re",
                "value": "^/api/(kling|kie|nanobanana|studio/generations/start)"
              }
            ]
          }
        ],
        "action": {
          "type": "rate_limit",
          "rateLimit": {
            "requests": 30,
            "window": "60s"
          }
        }
      },
      {
        "name": "Rate limit GPT analysis routes",
        "conditionGroup": [
          {
            "conditions": [
              {
                "type": "path",
                "op": "pre",
                "value": "/api/gpt/"
              }
            ]
          }
        ],
        "action": {
          "type": "rate_limit",
          "rateLimit": {
            "requests": 20,
            "window": "60s"
          }
        }
      },
      {
        "name": "Rate limit store extract (web scraping)",
        "conditionGroup": [
          {
            "conditions": [
              {
                "type": "path",
                "op": "eq",
                "value": "/api/store/extract"
              }
            ]
          }
        ],
        "action": {
          "type": "rate_limit",
          "rateLimit": {
            "requests": 10,
            "window": "60s"
          }
        }
      },
      {
        "name": "Rate limit Stripe checkout (anti-spam)",
        "conditionGroup": [
          {
            "conditions": [
              {
                "type": "path",
                "op": "pre",
                "value": "/api/stripe/checkout/"
              }
            ]
          }
        ],
        "action": {
          "type": "rate_limit",
          "rateLimit": {
            "requests": 5,
            "window": "60s"
          }
        }
      },
      {
        "name": "Rate limit download proxy",
        "conditionGroup": [
          {
            "conditions": [
              {
                "type": "path",
                "op": "eq",
                "value": "/api/download"
              }
            ]
          }
        ],
        "action": {
          "type": "rate_limit",
          "rateLimit": {
            "requests": 50,
            "window": "60s"
          }
        }
      }
    ]
  }
}
