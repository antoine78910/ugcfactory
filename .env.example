## KIE API (required for studio image via Google Nano Banana 2/Pro, video, Veo, Topaz upscale, Kling, …)
KIE_API_KEY=replace_me

## PiAPI (used for Seedance video models when KIE support is unavailable)
# PIAPI_API_KEY=replace_me

## NanoBanana direct API (optional — studio image routes use Kie only when KIE_API_KEY is set)
# NANOBANANA_API_KEY=

## OpenAI (GPT analysis) — all prompting uses Responses API; default model is gpt-5.2
OPENAI_API_KEY=replace_me
# Optional override (default = gpt-5.2)
# OPENAI_MODEL=gpt-5.2
# Anthropic (Claude 3.5 Sonnet) — optional; used when `provider=claude` is sent to /api/gpt/* routes
# ANTHROPIC_API_KEY=replace_me
# Optional override (default in code = claude-3-5-sonnet-latest)
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# Brand URL summary (Link to Ad) — default gpt-5-mini + web search tool in code
# OPENAI_BRAND_SUMMARY_MODEL=gpt-5-mini

## Public base URL used to build callback URLs + public upload URLs.
# In local dev, NanoBanana cannot reach localhost. Use a public URL (e.g. Cloudflare Tunnel)
# APP_URL=https://xxxx.trycloudflare.com
APP_URL=http://localhost:3000

## Comma / semicolon-separated emails allowed to open `/apitest` (personal KIE + PiAPI keys for internal testing).
## Empty or unset → no one can access that route (they are redirected to `/app`).
# API_TEST_ALLOWED_EMAILS=you@example.com,other@example.com

## Datafast (analytics — public, safe in browser)
# NEXT_PUBLIC_DATAFAST_WEBSITE_ID=dfid_CATofowr0YLBVK8sLAekT
# NEXT_PUBLIC_DATAFAST_DOMAIN=youry.io

## LinkJolt (affiliate tracking — public merchant id, safe in browser)
# Optional override; default in src/app/layout.tsx matches your merchant
# NEXT_PUBLIC_LINKJOLT_MERCHANT_ID=NKdBH0Xt51wfjtEIZB5Zg
#
# Manual Stripe Dashboard (required for conversions in LinkJolt):
# 1. Developers → Webhooks → Add endpoint
# 2. URL: https://www.linkjolt.io/api/webhooks/stripe/merchant/NKdBH0Xt51wfjtEIZB5Zg
# 3. Events: checkout.session.completed, invoice.payment_succeeded,
#    customer.subscription.updated, customer.subscription.deleted, charge.refunded
# 4. Save; copy Signing secret (whsec_…) — use it where LinkJolt instructs (often their dashboard),
#    not necessarily in this repo unless you add your own /api/stripe/webhook route.

## Stripe (subscriptions — Checkout)
# Dashboard → Developers → API keys (never commit real keys; use .env.local)
STRIPE_SECRET_KEY=sk_test_replace_me
# Optional: only if you add Stripe.js / Elements / Customer Portal (Checkout redirect does not need it)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Optional: Stripe Billing portal direct link used by "Manage billing" button
# NEXT_PUBLIC_STRIPE_BILLING_PORTAL_URL=https://billing.stripe.com/p/login/your_portal_link
# Signing secret for YOUR app’s Stripe webhook route only (this repo has no /api/stripe/webhook yet).
# LinkJolt uses its own endpoint at linkjolt.io — you do not need whsec here for LinkJolt alone.
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Subscription prices (recurring monthly) — Products → each price → Price ID
STRIPE_PRICE_SUBSCRIPTION_STARTER=price_1TDKLnCW2HDTjeZVCYoFMr7T
STRIPE_PRICE_SUBSCRIPTION_GROWTH=price_1TDKLbCW2HDTjeZV2H8Ggw8m
STRIPE_PRICE_SUBSCRIPTION_PRO=price_1TDKLQCW2HDTjeZVOreVWW2N
STRIPE_PRICE_SUBSCRIPTION_SCALE=price_1TDKLECW2HDTjeZVdpWu5VQ7
# Optional: yearly prices (enable “Yearly” checkout once created in Stripe)
# STRIPE_PRICE_SUBSCRIPTION_STARTER_YEARLY=
# STRIPE_PRICE_SUBSCRIPTION_GROWTH_YEARLY=
# STRIPE_PRICE_SUBSCRIPTION_PRO_YEARLY=
# STRIPE_PRICE_SUBSCRIPTION_SCALE_YEARLY=

# One-off credit packs (Checkout mode=payment) — order: Scale, Pro, Growth, Boost, Launch
STRIPE_PRICE_CREDITS_SCALE=price_1TDKQLCW2HDTjeZVos5sNcyq
STRIPE_PRICE_CREDITS_PRO=price_1TDKQ8CW2HDTjeZVjmn2kpLw
STRIPE_PRICE_CREDITS_GROWTH=price_1TDKPsCW2HDTjeZVrbazA9AP
STRIPE_PRICE_CREDITS_BOOST=price_1TDKPQCW2HDTjeZVrxpBltig
STRIPE_PRICE_CREDITS_LAUNCH=price_1TDKP8CW2HDTjeZVQKTryXgx

## Supabase (Auth + DB)
NEXT_PUBLIC_SUPABASE_URL=replace_me
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
# Production app host (OAuth). Must match Supabase Auth > URL Configuration:
# - Site URL: https://app.youry.io (or your app subdomain)
# - Redirect URLs: https://app.youry.io/auth/callback
# NEXT_PUBLIC_APP_URL=https://app.youry.io
# Optionnel : pour upload d’images en production (Vercel). Crée un bucket public « ugc-uploads » dans Supabase > Storage.
# SUPABASE_SERVICE_ROLE_KEY=replace_me

# Signup deferred "book a call" email — lives in Supabase Edge Functions (Resend), not in Next.js env:
# Run supabase/profiles_call_invite.sql, deploy supabase/functions/signup-call-invite-webhook + signup-call-invite-cron,
# set Edge secrets: RESEND_API_KEY, RESEND_FROM_EMAIL, CALL_INVITE_BOOKING_URL, CRON_SECRET; optional WEBHOOK_SECRET.
# Database Webhook: INSERT on public.profiles → webhook function URL; schedule cron with Authorization: Bearer <CRON_SECRET>.

## Brevo (email automation — server-side API key)
# Dashboard → Settings → API Keys → generate v3 key
# BREVO_API_KEY=xkeysib-replace_me
# Optional: comma-separated Brevo list IDs to auto-add new contacts to
# BREVO_DEFAULT_LIST_IDS=3

# Cron Railway / worker : POST /api/studio/generations/cron avec Authorization: Bearer <secret>
# pour finaliser les générations studio (sans clé perso) quand l’utilisateur a fermé l’onglet.
# STUDIO_GENERATIONS_CRON_SECRET=long_random_string

## Sentry (optional — leave unset locally if you do not use Sentry)
# Browser + server: public DSN from Sentry project settings
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# Optional server-only override (same DSN is fine for small teams)
# SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# Source maps on `next build` (token scopes: project:releases, org:read)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug

