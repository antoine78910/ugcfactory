## NanoBanana (image)
# Server-only API key (NEVER expose it to the browser)
NANOBANANA_API_KEY=replace_me

## KIE API (video - Veo 3.1 + Market models like Kling 3.0)
KIE_API_KEY=replace_me

## OpenAI (GPT analysis) — all prompting uses Responses API; default model is gpt-5.2
OPENAI_API_KEY=replace_me
# Optional override (default = gpt-5.2)
# OPENAI_MODEL=gpt-5.2
# Brand URL summary (Link to Ad) — default gpt-5-mini + web search tool in code
# OPENAI_BRAND_SUMMARY_MODEL=gpt-5-mini

## Public base URL used to build callback URLs + public upload URLs.
# In local dev, NanoBanana cannot reach localhost. Use a public URL (e.g. Cloudflare Tunnel)
# APP_URL=https://xxxx.trycloudflare.com
APP_URL=http://localhost:3000

## Stripe (subscriptions — Checkout)
# Dashboard → Developers → API keys (never commit real keys; use .env.local)
STRIPE_SECRET_KEY=sk_test_replace_me
# Optional: only if you add Stripe.js / Elements / Customer Portal (Checkout redirect does not need it)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
# Webhook signing secret when you implement server-side credit grants (checkout.session.completed)
# STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Subscription prices (recurring monthly) — Products → each price → Price ID
STRIPE_PRICE_SUBSCRIPTION_STARTER=price_1TDKLnCW2HDTjeZVCYoFMr7T
STRIPE_PRICE_SUBSCRIPTION_GROWTH=price_1TDKLbCW2HDTjeZV2H8Ggw8m
STRIPE_PRICE_SUBSCRIPTION_PRO=price_1TDKLQCW2HDTjeZVOreVWW2N
STRIPE_PRICE_SUBSCRIPTION_SCALE=price_1TDKLECW2HDTjeZVdpWu5VQ7
# Optional: yearly prices (enable “Yearly” checkout once created in Stripe)
# STRIPE_PRICE_SUBSCRIPTION_STARTER_YEARLY=
# STRIPE_PRICE_SUBSCRIPTION_GROWTH_YEARLY=
# STRIPE_PRICE_SUBSCRIPTION_PRO_YEARLY=
# STRIPE_PRICE_SUBSCRIPTION_SCALE_YEARLY=

# One-off credit packs (Checkout mode=payment) — order: Scale, Pro, Growth, Boost, Launch
STRIPE_PRICE_CREDITS_SCALE=price_1TDKQLCW2HDTjeZVos5sNcyq
STRIPE_PRICE_CREDITS_PRO=price_1TDKQ8CW2HDTjeZVjmn2kpLw
STRIPE_PRICE_CREDITS_GROWTH=price_1TDKPsCW2HDTjeZVrbazA9AP
STRIPE_PRICE_CREDITS_BOOST=price_1TDKPQCW2HDTjeZVrxpBltig
STRIPE_PRICE_CREDITS_LAUNCH=price_1TDKP8CW2HDTjeZVQKTryXgx

## Supabase (Auth + DB)
NEXT_PUBLIC_SUPABASE_URL=replace_me
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
# Production app host (OAuth). Must match Supabase Auth > URL Configuration:
# - Site URL: https://app.youry.io (or your app subdomain)
# - Redirect URLs: https://app.youry.io/auth/callback
# NEXT_PUBLIC_APP_URL=https://app.youry.io
# Optionnel : pour upload d’images en production (Vercel). Crée un bucket public « ugc-uploads » dans Supabase > Storage.
# SUPABASE_SERVICE_ROLE_KEY=replace_me

